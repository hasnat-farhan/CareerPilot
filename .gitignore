scripts/dev-eval.mjs
scripts/dev-eval-detached.mjs
scripts/dev-eval.pid
scripts/run-evals.cmd
scripts/start-dev.cmd
scripts/probe-eval-parse.js
scripts/inspect-saved.ts
scripts/smoke-tavily.ts

